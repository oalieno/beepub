# PostgreSQL
POSTGRES_DB=beepub
POSTGRES_USER=beepub
POSTGRES_PASSWORD=changeme

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Logging format: "console" (pretty, colored) or "json" (machine-readable)
LOG_FORMAT=console

# App port (nginx)
PORT=80

# CORS: comma-separated list of public web origins allowed to call the API.
# Capacitor (capacitor://localhost, ionic://localhost) and localhost browser
# origins on any port are always allowed.
# Example: CORS_ORIGINS=https://beepub.example.com,https://reader.example.com
CORS_ORIGINS=
