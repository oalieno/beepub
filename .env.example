# PostgreSQL
POSTGRES_DB=beepub
POSTGRES_USER=beepub
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Storage paths (inside container)
BOOKS_DIR=/data/books
COVERS_DIR=/data/covers

# Logging format: "console" (pretty, colored) or "json" (machine-readable)
LOG_FORMAT=console

# App port (nginx)
PORT=80

# CORS: comma-separated list of web origins allowed to call the API.
# Capacitor (capacitor://localhost, ionic://localhost) and http(s)://localhost
# are always allowed. Set this to your public URL(s).
# Example: CORS_ORIGINS=https://beepub.example.com,https://reader.example.com
CORS_ORIGINS=

# Set DEV=true to also allow common dev-server origins (vite :5173, etc.).
DEV=false
